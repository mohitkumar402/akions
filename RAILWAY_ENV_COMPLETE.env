# ============================================
# EKIONS BACKEND - COMPLETE ENVIRONMENT VARIABLES
# ============================================
# Copy all variables below (except PORT) and paste them into Railway → Settings → Variables
# Replace all YOUR_* placeholders with your actual values
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================
# ⚠️ DO NOT SET PORT - Railway sets it automatically!
NODE_ENV=production

# ============================================
# MONGODB DATABASE CONNECTION
# ============================================
# Replace with your MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/ekions?retryWrites=true&w=majority
# ⚠️ IMPORTANT: Database name must be /ekions (not /akions)
MONGODB_URI=mongodb+srv://YOUR_MONGODB_USERNAME:YOUR_MONGODB_PASSWORD@YOUR_CLUSTER.mongodb.net/ekions?retryWrites=true&w=majority

# ============================================
# JWT AUTHENTICATION SECRET
# ============================================
# Generate a secure random string (minimum 32 characters)
# You can generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY_MINIMUM_32_CHARACTERS_LONG_CHANGE_THIS

# ============================================
# RAZORPAY PAYMENT GATEWAY
# ============================================
# Get your keys from: https://dashboard.razorpay.com/app/keys
# Use Test keys for development, Live keys for production
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
# For Gmail, you need to use an App Password:
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Enable 2-Step Verification first if not already enabled
# 3. Generate an App Password for "Mail"
# 4. Use that password as SMTP_PASS

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# SMTP Authentication (Gmail example)
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD

# Admin Email (where internship applications and contact forms will be sent)
ADMIN_EMAIL=admin@ekions.com

# ============================================
# ALTERNATIVE EMAIL PROVIDERS
# ============================================
# If using Outlook/Hotmail, change these:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false

# If using SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=YOUR_SENDGRID_API_KEY

# If using Mailgun:
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=YOUR_MAILGUN_USERNAME
# SMTP_PASS=YOUR_MAILGUN_PASSWORD

# ============================================
# NOTES FOR RAILWAY:
# ============================================
# 1. Copy all variables above (EXCEPT PORT) to Railway
# 2. Replace all YOUR_* placeholders with actual values
# 3. Do not include the comments (lines starting with #)
# 4. Make sure variable names have no spaces (use underscores)
# 5. Make sure all values are filled (no empty values)
# 6. Save and redeploy
# ============================================


