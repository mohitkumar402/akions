# ============================================
# AKIONS BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env: cp env.template .env
# Then fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Database Connection
# Local MongoDB: mongodb://localhost:27017/akions
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/akions
MONGODB_URI=mongodb+srv://akionsdevteam:Mohit%40%24123@ekions.edczomg.mongodb.net/akions?retryWrites=true&w=majority

# JWT Authentication Secret Key
# Generated secure key - DO NOT SHARE OR COMMIT TO GIT
JWT_SECRET=17ad3bd882f17e506be2e7c39c2aeeba2e6c6f8c3cadabfa1869c660074a4e7b292df0157bc28eb06617451065c2a65ce97c1781a3ebaf8f5fdbdfda8b2387d7

# Razorpay Payment Gateway Configuration
# Get your keys from: https://dashboard.razorpay.com/app/keys
# Test Mode Keys (for development)
RAZORPAY_KEY_ID=rzp_test_1234567890
RAZORPAY_KEY_SECRET=test_secret_1234567890

# Production Razorpay Keys (uncomment and use in production)
# RAZORPAY_KEY_ID=rzp_live_YOUR_LIVE_KEY_ID
# RAZORPAY_KEY_SECRET=YOUR_LIVE_KEY_SECRET

# CORS Configuration (optional - defaults to allow all)
# CORS_ORIGIN=http://localhost:8082,http://localhost:19006

# ============================================
# SECURITY NOTES:
# ============================================
# 1. Never commit this file to version control
# 2. Use different keys for development and production
# 3. Rotate JWT_SECRET periodically in production
# 4. Use strong passwords for MongoDB
# 5. Enable MongoDB authentication in production
