# Backend environment variables – copy to .env and fill in values

PORT=3000
NODE_ENV=development

# Required in production (server will exit if missing). Dev uses fallback if not set.
JWT_SECRET=change-me-dev-secret

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Admin user (for script: npm run create:admin). Required in production; dev defaults used if not set.
ADMIN_EMAIL=admin@akions.com
ADMIN_PASSWORD=Admin@Local123
ADMIN_NAME=Admin User

# Razorpay (required for payment routes in production)
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Optional: extra CORS origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# Optional: SMTP for emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ADMIN_EMAIL=admin@yourdomain.com
